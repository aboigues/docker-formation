# TP7 — Version NAÏVE (mono-étage), volontairement mauvaise.
# Sert UNIQUEMENT à comparer la taille avec le Dockerfile multi-stage.
# On garde toute la toolchain Go (~490 Mo) dans l'image finale : à proscrire.
# syntax=docker/dockerfile:1
ARG GO_VERSION=1.26
FROM golang:${GO_VERSION}-alpine
WORKDIR /src
COPY . .
ARG VERSION=dev
RUN CGO_ENABLED=0 go build -ldflags="-X main.version=${VERSION}" -o /server .
EXPOSE 8080
ENTRYPOINT ["/server"]
